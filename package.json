{
  "name": "sonic-pi-web-root",
  "version": "0.1.0",
  "private": true,
  "description": "Sonic Pi Web monorepo",
  "type": "module",
  "bin": {
    "sonic-pi-web": "./bin/cli.js"
  },
  "main": "src/engine/index.ts",
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --config vite.build.config.ts"
  },
  "keywords": [
    "sonic-pi",
    "live-coding",
    "music",
    "web-audio",
    "supercollider",
    "scheduler"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}

{
  "name": "@mjayb/sonicpijs",
  "version": "1.3.0",
  "description": "SonicPi.js — browser-native Sonic Pi with real SuperCollider synthesis via WebAssembly",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "sonicpi": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.cjs",
    "dist/index.cjs.map",
    "dist/types"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --config vite.build.config.ts",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "sonic-pi",
    "live-coding",
    "music",
    "web-audio",
    "supercollider",
    "scheduler",
    "webaudio",
    "wasm"
  ],
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrityunjayBhardwaj/sonicpi.js.git"
  },
  "bugs": {
    "url": "https://github.com/MrityunjayBhardwaj/sonicpi.js/issues"
  },
  "homepage": "https://sonicpi.cc",
  "license": "MIT"
}

{
  "name": "sonicpi",
  "version": "1.3.0",
  "description": "SonicPi.js — browser-native Sonic Pi with real SuperCollider synthesis via WebAssembly",
  "type": "module",
  "bin": {
    "sonicpi": "./bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "public",
    "index.html",
    "vite.build.config.ts",
    "vitest.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "vite build",
    "build:single": "vite build --config vite.build.config.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "sonic-pi",
    "live-coding",
    "music",
    "web-audio",
    "supercollider",
    "scheduler",
    "webaudio",
    "wasm"
  ],
  "dependencies": {
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.7.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrityunjayBhardwaj/sonicpi.js.git"
  },
  "bugs": {
    "url": "https://github.com/MrityunjayBhardwaj/sonicpi.js/issues"
  },
  "homepage": "https://github.com/MrityunjayBhardwaj/sonicpi.js#readme",
  "license": "MIT"
}
